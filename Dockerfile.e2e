FROM node:20-bookworm

WORKDIR /app

# Install Playwright
COPY e2e/package.json ./e2e-package.json
RUN npm install @playwright/test@1.52.0 && npx playwright install --with-deps chromium

# Copy everything (test files need access to helpers etc.)
COPY e2e/ ./e2e/
COPY playwright.config.ts ./

# Default: run tests
CMD ["npx", "playwright", "test", "--reporter=list"]
